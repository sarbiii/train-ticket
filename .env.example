# KTX 스나이퍼 환경변수
# 복사 후 .env 로 저장: cp .env.example .env && chmod 600 .env

# Korail 회원 로그인 정보
# - 휴대폰번호 형식: 01012345678 (하이픈 제외)
# - 이메일 형식:    example@email.com
# - 회원번호 형식:  숫자 (Korail 앱/웹 마이페이지에서 확인)
KSKILL_KTX_ID=
KSKILL_KTX_PASSWORD=

# SRT 로그인 정보 (회원번호 / 이메일 / 휴대폰번호)
KSKILL_SRT_ID=
KSKILL_SRT_PASSWORD=

# Discord 웹훅 (예매 성공 시 알림, 선택)
DISCORD_WEBHOOK_URL=

# Discord slash-command 봇 (app_discord.py)
DISCORD_BOT_TOKEN=
# 테스트 중 특정 서버에만 빠르게 명령 동기화하려면 서버 ID를 지정
DISCORD_GUILD_ID=
# 선택 allowlist. 쉼표/공백 구분, 비워두면 전체 허용
DISCORD_ALLOWED_CHANNEL_IDS=
DISCORD_ALLOWED_USER_IDS=
